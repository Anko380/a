local function gucci_grab(prt) 
    if not prt or not prt:IsA("BasePart") then return end
    local grabEvents = ReplicatedStorage:FindFirstChild("GrabEvents")
    if grabEvents and grabEvents:FindFirstChild("SetNetworkOwner") then
        grabEvents.SetNetworkOwner:FireServer(prt, prt.CFrame) 
    end
end

local function toy_spawn_gucci(name, cframe, vector)
    local toyFolder = Workspace:FindFirstChild(me.Name .. 'SpawnedInToys')
    if not toyFolder then return nil end

    local spawnedToy = nil
    local connection
    connection = toyFolder.ChildAdded:Connect(function(toy)
        if toy.Name == name then
            spawnedToy = toy
            connection:Disconnect()
        end
    end)

    task.spawn(function()
        local menuToys = ReplicatedStorage:FindFirstChild("MenuToys")
        if menuToys and menuToys:FindFirstChild("SpawnToyRemoteFunction") then
            menuToys.SpawnToyRemoteFunction:InvokeServer(name, cframe, vector or Vector3.new())
        end
    end)
    
    local waitStart = tick()
    while not spawnedToy and tick() - waitStart < 4 do
        RunService.Heartbeat:Wait()
    end
    if connection then connection:Disconnect() end
    return spawnedToy
end

local function ExecuteGucciAntiGrab()
    State.GucciRunId = State.GucciRunId + 1
    local MyId = State.GucciRunId
    local isSetupFinished = false
    
    local char = me.Character or me.CharacterAdded:Wait()
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    
    if not (hum and hrp) then return end

    hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)

    -- 慣性リセット
    task.spawn(function()
        local t = tick()
        while tick() - t < 0.8 and MyId == State.GucciRunId do
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            RunService.Heartbeat:Wait()
        end
    end)

    local Blob = toy_spawn_gucci("CreatureBlobman", hrp.CFrame * CFrame.new(0, 0, -5), Vector3.new(0, -15.716, 0))
    if not Blob then 
        Rayfield:Notify({Title = "Error", Content = "Spawn Failed.", Duration = 3})
        return 
    end

    local BHead = Blob:WaitForChild("Head", 3)
    local HitBox = Blob:WaitForChild("GrabbableHitbox", 3)
    local Seat = Blob:WaitForChild("VehicleSeat", 3)

    task.spawn(function()
        local startTime = tick()
        while MyId == State.GucciRunId and not isSetupFinished and tick() - startTime < 1.2 do
            gucci_grab(HitBox)
            gucci_grab(BHead)
            if Seat and Seat.Occupant ~= hum then Seat:Sit(hum) end
            local charEvents = ReplicatedStorage:FindFirstChild("CharacterEvents")
            if charEvents and charEvents:FindFirstChild("RagdollRemote") then
                charEvents.RagdollRemote:FireServer(hrp, 0.09)
            end
            RunService.Heartbeat:Wait()
        end
    end)

    task.wait(0.45)
    if MyId ~= State.GucciRunId then if Blob then Blob:Destroy() end return end
    
    isSetupFinished = true 
    hum.Sit = false
    
    if Seat then
        Seat.Disabled = true; Seat.CanTouch = false; Seat.CanQuery = false 
        for _, v in pairs(Seat:GetChildren()) do
            if v:IsA("Weld") or v.Name == "SeatWeld" then v:Destroy() end
        end
    end
    
    hum:ChangeState(Enum.HumanoidStateType.Jumping)
    task.wait(0.05)
    local charEvents = ReplicatedStorage:FindFirstChild("CharacterEvents")
    if charEvents and charEvents:FindFirstChild("RagdollRemote") then
        charEvents.RagdollRemote:FireServer(hrp, false)
    end
    hum:ChangeState(Enum.HumanoidStateType.GettingUp)
    
    Blob.Name = "Gucci"
    for _, v in pairs(Blob:GetDescendants()) do
        if v:IsA("BasePart") then
            v.CanCollide = false; v.CanTouch = false; v.CanQuery = false; v.Massless = true
        end
    end

    task.spawn(function()
        while MyId == State.GucciRunId and BHead and BHead.Parent do
            BHead.CFrame = CFrame.new(BHead.Position.X, 100000, BHead.Position.Z)
            RunService.Heartbeat:Wait()
        end
    end)

    Rayfield:Notify({Title = "Success", Content = "Gucci System Active!", Duration = 3})
end

