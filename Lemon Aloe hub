local function getTeamColor(player)
    if player.Team then return player.Team.TeamColor.Color end
    return Color3.fromRGB(255, 50, 50)
end

local function createESPForPlayer(player)
    if player == me then return end
    local gui = Instance.new("BillboardGui")
    gui.Name = "ESP_" .. player.Name
    gui.AlwaysOnTop = true
    gui.Size = UDim2.new(0, 120, 0, 70)
    gui.StudsOffset = Vector3.new(0, 3, 0)
    gui.Parent = ESPFolder

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Name = "NameLabel"; nameLabel.BackgroundTransparency = 1; nameLabel.Size = UDim2.new(1, 0, 0.35, 0)
    nameLabel.Font = Enum.Font.GothamBold; nameLabel.TextSize = 13; nameLabel.TextStrokeTransparency = 0.4
    nameLabel.Text = player.Name; nameLabel.TextColor3 = getTeamColor(player); nameLabel.Parent = gui

    local distLabel = Instance.new("TextLabel")
    distLabel.Name = "DistLabel"; distLabel.BackgroundTransparency = 1; distLabel.Size = UDim2.new(1, 0, 0.3, 0)
    distLabel.Position = UDim2.new(0, 0, 0.35, 0); distLabel.Font = Enum.Font.Gotham; distLabel.TextSize = 11
    distLabel.TextStrokeTransparency = 0.4; distLabel.TextColor3 = Color3.fromRGB(220, 220, 220); distLabel.Parent = gui

    local hpBG = Instance.new("Frame")
    hpBG.Name = "HPBG"; hpBG.BackgroundColor3 = Color3.fromRGB(30, 30, 30); hpBG.BorderSizePixel = 0; hpBG.Size = UDim2.new(1, 0, 0.18, 0)
    hpBG.Position = UDim2.new(0, 0, 0.72, 0); hpBG.Parent = gui

    local hpBar = Instance.new("Frame")
    hpBar.Name = "HPBar"; hpBar.BackgroundColor3 = Color3.fromRGB(80, 255, 80); hpBar.BorderSizePixel = 0; hpBar.Size = UDim2.new(1, 0, 1, 0); hpBar.Parent = hpBG

    local line = Drawing.new("Line")
    line.Thickness = 1; line.Color = getTeamColor(player); line.Transparency = 0.3; line.Visible = false

    ESPObjects[player] = { Gui = gui, NameLabel = nameLabel, DistLabel = distLabel, HPBar = hpBar, HPBG = hpBG, Line = line }
end

local function removeESPForPlayer(player)
    if ESPObjects[player] then
        if ESPObjects[player].Gui then ESPObjects[player].Gui:Destroy() end
        if ESPObjects[player].Line then ESPObjects[player].Line:Remove() end
        ESPObjects[player] = nil
    end
end

local function clearAllESP() for player, _ in pairs(ESPObjects) do removeESPForPlayer(player) end end
local function initESP() for _, p in pairs(Players:GetPlayers()) do createESPForPlayer(p) end end

