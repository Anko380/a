local function FWC(Parent, Name, Time)
    return Parent:FindFirstChild(Name) or Parent:WaitForChild(Name, Time)
end

local function ServerHop()
    local Servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"))
    for _, s in pairs(Servers.data) do
        if s.playing < s.maxPlayers and s.id ~= game.JobId then
            TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id, me)
            break
        end
    end
end

local function sendChat(msg)
    local success = pcall(function()
        ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
            :FindFirstChild("SayMessageRequest"):FireServer(msg, "All")
    end)
    if not success then
        pcall(function()
            game:GetService("Chat"):Chat(me.Character and me.Character:FindFirstChild("Head"), msg)
        end)
    end
end

