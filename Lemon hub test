-- Optimization: Conflict-Free Physics Sync & Packet Prioritization

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

-- // 内部変数
local State = {
    Active = false,
}

local SETTINGS = {
    MAX_ATTACK_FRAMES = 8, -- スピード維持
    OFFSET = CFrame.new(0, 0, 2.35) -- 物理競合を避ける最適距離
}

-- // 高度な生存確認
local function IsValidTarget(player)
    if player == LocalPlayer then return false end
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    return char and root and hum and hum.Health > 0 and char.Parent == workspace
end

-- // 外科的精度・殲滅ロジック
local function ExecuteSurgicalKill()
    local GE = ReplicatedStorage:WaitForChild("GrabEvents", 5)
    if not GE then return end

    while State.Active do
        local survivors = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if IsValidTarget(p) then table.insert(survivors, p) end
        end

        for _, target in ipairs(survivors) do
            if not State.Active then break end
            
            local myChar = LocalPlayer.Character
            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

            if IsValidTarget(target) and myRoot then
                local tChar = target.Character
                local tRoot = tChar.HumanoidRootPart
                local tHum = tChar.Humanoid

                -- // 超高速・高精度サイクル
                for i = 1, SETTINGS.MAX_ATTACK_FRAMES do
                    if not IsValidTarget(target) or not State.Active then break end
                    
                    -- 【精度向上】ターゲットの背後へ完全に「固定」
                    myRoot.CFrame = tRoot.CFrame * SETTINGS.OFFSET
                    
                    -- 物理的反発を殺すためのベロシティ・アンカー
                    myRoot.AssemblyLinearVelocity = Vector3.new(0, -1, 0) -- わずかに下に押し付ける
                    myRoot.AssemblyAngularVelocity = Vector3.zero

                    pcall(function()
                        -- 物理権利を確実に上書き
                        GE.SetNetworkOwner:FireServer(tRoot, myRoot.CFrame)
                        
                        -- ステート操作（キル手法は完全維持）
                        -- ターゲットのステートを毎フレームDeadに固定し、サーバーの回復を許さない
                        tHum:ChangeState(Enum.HumanoidStateType.Dead)
                        tHum.BreakJointsOnDeath = true
                        
                        -- 判定を「面」で作るための多重パケット
                        GE.CreateGrabLine:FireServer(tRoot, Vector3.new(0, -200, 0), tRoot.Position, true)
                        GE.CreateGrabLine:FireServer(tRoot, Vector3.new(0, 0, 0), tRoot.Position + Vector3.new(0,1,0), false)
                        GE.DestroyGrabLine:FireServer(tRoot)
                    end)
                    
                    RunService.Heartbeat:Wait()
                end
                -- 遷移スピード維持のため、位置復元は行わず即座に次のターゲットへ
            end
        end
        
        -- 全滅時はリソース節約
        if #survivors == 0 then
            RunService.Heartbeat:Wait()
        end
    end
end

