-- [Quantum Engine]
local function IsValidTarget(player)
    if player == LocalPlayer then return false end
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChildOfClass("Humanoid") and char:FindFirstChildOfClass("Humanoid").Health > 0
end

local function ExecuteQuantumKill()
    local GE = ReplicatedStorage:WaitForChild("GrabEvents", 5)
    if not GE then return end
    while State.MassKillActive do
        for _, target in ipairs(Players:GetPlayers()) do
            if IsValidTarget(target) and State.MassKillActive then
                local tRoot = target.Character.HumanoidRootPart
                pcall(function()
                    GE.SetNetworkOwner:FireServer(tRoot, tRoot.CFrame)
                    GE.CreateGrabLine:FireServer(tRoot, Vector3.new(0, -500, 0), tRoot.Position, true)
                    GE.DestroyGrabLine:FireServer(tRoot)
                end)
            end
        end
        RunService.Heartbeat:Wait()
    end
end

-- [Minimap Engine]
local function UpdateMinimap()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not State.MinimapVisible then return end
    
    if (root.Position - lastScanPos).Magnitude > 4 then
        lastScanPos = root.Position
        for x = 1, State.GridRes do
            for y = 1, State.GridRes do
                local offX = ((x - 1) / (State.GridRes - 1) - 0.5) * State.ZoomLevel
                local offZ = ((y - 1) / (State.GridRes - 1) - 0.5) * State.ZoomLevel
                local ray = Workspace:Raycast(root.Position + Vector3.new(offX, 100, offZ), Vector3.new(0, -200, 0))
                if mapPixels[x] and mapPixels[x][y] then
                    mapPixels[x][y].BackgroundColor3 = ray and Color3.fromRGB(50, 100, 50) or Color3.fromRGB(10, 10, 15)
                end
            end
        end
    end
end

