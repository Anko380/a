AntiTab:CreateButton({
    Name = "全削除",
    Callback = function()
        pcall(function()
            local count = 0
            for _, v in pairs(workspace:GetDescendants()) do
                if v.Name == "Blobman" and v:IsA("Model") then
                    v:Destroy()
                    count = count + 1
                end
