-- Blobmanをスポーンする関数
local function spawnBlobman()
    pcall(function()
        print("Blobmanをスポーンします")
        
        -- Blobmanモデルを作成
        local blobman = Instance.new("Model")
        blobman.Name = "Blobman"
        
        -- Humanoidを作成
        local humanoid = Instance.new("Humanoid")
        humanoid.Name = "Humanoid"
        humanoid.Parent = blobman
        
        -- HumanoidRootPartを作成
        local rootPart = Instance.new("Part")
        rootPart.Name = "HumanoidRootPart"
        rootPart.Size = Vector3.new(2, 2, 1)
        rootPart.Anchored = false
        rootPart.CanCollide = true
        rootPart.Parent = blobman
        
        -- 頭部
        local head = Instance.new("Part")
        head.Name = "Head"
        head.Size = Vector3.new(1.5, 1.5, 1.5)
        head.Anchored = false
        head.CanCollide = true
        head.Parent = blobman
        
        -- 胴体
        local torso = Instance.new("Part")
        torso.Name = "Torso"
        torso.Size = Vector3.new(2, 2, 1)
        torso.Anchored = false
        torso.CanCollide = true
        torso.Parent = blobman
        
        -- 四肢
        local limbs = {"Left Arm", "Right Arm", "Left Leg", "Right Leg"}
        for _, limbName in ipairs(limbs) do
            local limb = Instance.new("Part")
            limb.Name = limbName
            limb.Size = Vector3.new(1, 1.5, 1)
            limb.Anchored = false
            limb.CanCollide = true
            limb.Parent = blobman
        end
        
        -- 関節を作成して接続
        local function createWeld(part0, part1, c0, c1)
            local weld = Instance.new("Weld")
            weld.Part0 = part0
            weld.Part1 = part1
            weld.C0 = c0 or CFrame.new()
            weld.C1 = c1 or CFrame.new()
            weld.Parent = part0
            return weld
        end
        
        -- RootPartを基準に各パーツを配置
        rootPart.CFrame = CFrame.new(0, 3, 0)
        torso.CFrame = rootPart.CFrame * CFrame.new(0, -1, 0)
        head.CFrame = torso.CFrame * CFrame.new(0, 1.2, 0)
        
        -- 腕と脚の位置
        local leftArm = blobman:FindFirstChild("Left Arm")
        local rightArm = blobman:FindFirstChild("Right Arm")
        local leftLeg = blobman:FindFirstChild("Left Leg")
        local rightLeg = blobman:FindFirstChild("Right Leg")
        
        if leftArm then leftArm.CFrame = torso.CFrame * CFrame.new(-1.2, 0.5, 0) end
        if rightArm then rightArm.CFrame = torso.CFrame * CFrame.new(1.2, 0.5, 0) end
        if leftLeg then leftLeg.CFrame = torso.CFrame * CFrame.new(-0.6, -1.2, 0) end
        if rightLeg then rightLeg.CFrame = torso.CFrame * CFrame.new(0.6, -1.2, 0) end
        
        -- ウェルドで接続
        createWeld(torso, head, CFrame.new(0, 1.2, 0))
        createWeld(torso, leftArm, CFrame.new(-1.2, 0.5, 0))
        createWeld(torso, rightArm, CFrame.new(1.2, 0.5, 0))
        createWeld(torso, leftLeg, CFrame.new(-0.6, -1.2, 0))
        createWeld(torso, rightLeg, CFrame.new(0.6, -1.2, 0))
        createWeld(rootPart, torso, CFrame.new(0, -1, 0))
        
        -- HumanoidにRootPartを設定
        humanoid:SetRootPart(rootPart)
        
        -- スポーン位置をプレイヤーの前に設定
        local player = game.Players.LocalPlayer
        local character = player.Character or player.CharacterAdded:Wait()
        local playerRoot = character and character:FindFirstChild("HumanoidRootPart")
        
        if playerRoot then
            blobman.Parent = workspace
            rootPart.CFrame = playerRoot.CFrame + playerRoot.CFrame.LookVector * 5
            
            -- 座らせる
            task.wait(0.3)
            humanoid.Sit = true
            
            -- 高速ラグドール化
            task.wait(0.2)
            
            -- 全関節を破壊
            for _, v in pairs(blobman:GetDescendants()) do
                if v:IsA("Weld") or v:IsA("Motor6D") then
                    v:Destroy()
                end
            end
            
            -- 物理演算モードに変更
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Physics, true)
            humanoid:ChangeState(Enum.HumanoidStateType.Physics)
            
            -- 全パーツを物理演算対象に
            for _, v in pairs(blobman:GetDescendants()) do
                if v:IsA("BasePart") then
                    v:SetNetworkOwner(nil)
                    v.Velocity = Vector3.new(math.random(-50, 50), math.random(20, 80), math.random(-50, 50))
                    v.AngularVelocity = Vector3.new(math.random(-30, 30), math.random(-30, 30), math.random(-30, 30))
                end
            end
            
            if Rayfield.Notify then
                Rayfield:Notify({
                    Title = "anti",
                    Content = "Blobmanが座って高速ラグドール状態になりました",
                    Duration = 3
                })
            end
            
            print("Blobmanが座って高速ラグドール状態になりました")
        end
    end)
end

-- antiタブにトグルを追加（押したらBlobmanをスポーン）
