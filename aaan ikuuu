local function DoThorwEvents(Object)
	local GrabingObject = Object
	local OwnerObject = GrabingObject.Parent
	local SetNetworkOwner = game:GetService("ReplicatedStorage"):FindFirstChild("GrabEvents"):FindFirstChild("SetNetworkOwner")

	
	if Throwing then
		print("Throw - " .. tostring(GrabingObject))
		if ThrowNIL then
			local model = Object
			local main = model.PrimaryPart
			if not main then return end

			for _, part in model:GetDescendants() do
				if part:IsA("BasePart") then
					part.Anchored = false
				end
			end
			
			SetNetworkOwner:FireServer(player)
			
			main.AssemblyLinearVelocity = Vector3.zero
			main.AssemblyAngularVelocity = Vector3.zero

			local throwPower = Throw -- your force value
			local direction = workspace.CurrentCamera.CFrame.LookVector

			main:ApplyImpulse(direction * throwPower * main.AssemblyMass)
		end
	else
		print("Droped - " .. tostring(GrabingObject))
	end
	print("Owner - ".. tostring(OwnerObject))
end

local function DoMovementFaster()
		local Character = game.Players.LocalPlayer.Character
		local Humanoid = Character:FindFirstChild("Humanoid")
		local Camera = game.Workspace.CurrentCamera

		if WalkSpeedNIL == true and Shifting then
			Humanoid.WalkSpeed = WalkSpeed
		elseif WalkSpeedNIL == false or not Shifting then
			Humanoid.WalkSpeed = WalkSpeedDefault
		end
		if JumpHightNIL == true and Shifting then
			Humanoid.JumpPower = JumpPower
		elseif JumpHightNIL == false or not Shifting then
			Humanoid.JumpPower = JumpPowerDefault
		end
		if FovNIL == true then
			Camera.FieldOfView = FOV
		elseif FovNIL == false then
			Camera.FieldOfView = FOVDefault
		end
		if ThrowNIL == true then
			local GrabPart = workspace:FindFirstChild("GrabParts")
			
			if GrabPart then
				local GrabPart = GrabPart:FindFirstChild("GrabPart")
				if not GrabPart then warn("GrabPart was not found") return end
				local BeamAttach = GrabPart:FindFirstChild("WeldConstraint")
				if not BeamAttach then warn("BeamAttach was not found") return end
				
				local ObjectModel = BeamAttach.Part1.Parent
				if not ObjectModel then warn("BeamAttach was not found") return end
				
				Grabing = true
				
				while Grabing do
						local update = workspace:FindFirstChild("GrabParts")
						
						if not update then
							DoThorwEvents(ObjectModel)
							Grabing = false
						end
						
						wait()
				end
			end
	end
end

